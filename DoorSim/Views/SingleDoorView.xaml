<UserControl x:Class="DoorSim.Views.SingleDoorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:DoorSim.Views"
             Background="#1E1E1E"
             Foreground="White">

    <Grid Margin="20">

        <!--
            Reusable single-door hardware panel.

            SingleDoorView is now a lightweight host around DoorPanelView.
        
            The DataContext is forwarded unchanged, so the panel uses the same DoorsViewModel selected by MainWindow / DoorSelectorView.

            This wrapper keeps Single Door mode separate from Two Door mode while allowing both layouts to share the same interactive door UI.
        -->
        <views:DoorPanelView DataContext="{Binding}"/>

    </Grid>
    
</UserControl>