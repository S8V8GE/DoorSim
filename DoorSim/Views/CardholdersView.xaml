<UserControl x:Class="DoorSim.Views.CardholdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E"
             Foreground="White">

    <UserControl.Resources>

        <!-- Header style -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <!-- Row style -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>

            <Style.Triggers>
                <!-- Hover highlight -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A4A73"/>
                </Trigger>

                <!-- Selected row highlight -->
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#007ACC"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <!--
    Cardholders panel.

    Responsible for:
    - Showing cardholders loaded from SQL
    - Providing a search box
    - Showing an empty message if no cardholders exist

    Later:
    - Cardholders will be draggable onto door readers.
    -->
    
    <Grid>
        
        <Border BorderBrush="#3F3F46"
                BorderThickness="1"
                Background="#1E1E1E"
                Margin="10"
                Padding="10">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title bar with search -->
                <Border Grid.Row="0"
                        Background="#1F3A5F"
                        Padding="10,6"> 

                    <DockPanel LastChildFill="False">

                        <StackPanel Orientation="Horizontal"
                                    DockPanel.Dock="Left"
                                    VerticalAlignment="Center">

                            <TextBlock Text="👥 Cardholders"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBlock Text="{Binding CardholderCount, StringFormat=' ({0} credentials configured)'}"
                                       Margin="8,0,0,0"
                                       FontSize="12"
                                       Foreground="#CCCCCC"
                                       VerticalAlignment="Bottom"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    DockPanel.Dock="Right"
                                    VerticalAlignment="Center">

                            <TextBlock Text="🔍"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>

                            <TextBox Width="220"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#2D2D30"
                                     Foreground="White"
                                     BorderBrush="#555555"
                                     Padding="6"
                                     ToolTip="Search cardholders"/>
                        </StackPanel>

                    </DockPanel>
                
                </Border>

                <!-- Cardholder list -->
                <DataGrid x:Name="CardholdersGrid"
                          Grid.Row="2"
                          ItemsSource="{Binding VisibleCardholders}"
                          PreviewMouseMove="CardholdersGrid_PreviewMouseMove"
                          GiveFeedback="CardholdersGrid_GiveFeedback"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          Background="#1E1E1E"
                          Foreground="White"
                          RowBackground="#1E1E1E"
                          AlternatingRowBackground="#252526"
                          GridLinesVisibility="All"
                          VerticalGridLinesBrush="#3F3F46"
                          HorizontalGridLinesBrush="#3F3F46">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Cardholder Name"
                                            Binding="{Binding CardholderName}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Credential (Raw Hexadecimal)"
                                            Binding="{Binding TrimmedCredential}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Bit Count"
                                            Binding="{Binding BitCount}"
                                            Width="100"/>

                        <DataGridCheckBoxColumn Header="Has PIN"
                                                Binding="{Binding HasPin}"
                                                Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Floating credential image shown while dragging a cardholder -->
        <Popup x:Name="CredentialDragPopup"
               Placement="Absolute"
               AllowsTransparency="True"
               IsHitTestVisible="False">

            <Image Source="/Images/Credential.png"
                   Width="64"
                   Height="64"
                   Opacity="0.65"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   SnapsToDevicePixels="True"/>
        </Popup>

    </Grid>

</UserControl>