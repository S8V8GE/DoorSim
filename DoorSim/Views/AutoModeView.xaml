<UserControl x:Class="DoorSim.Views.AutoModeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="300">

    <!--
        Auto Mode page.

        Provides:
            - simulation settings
            - start/stop/clear controls
            - running summary
            - scrollable event log

        Real Softwire simulation logic will be added later.
    -->

    <Grid Background="#1E1E1E"
          Margin="14">

        <Grid.RowDefinitions>
            
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0"
                    Margin="0,0,0,12">

            <TextBlock Text="{Binding Title}"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="White"/>

            <TextBlock Text="{Binding Subtitle}"
                       FontSize="14"
                       Foreground="#CCCCCC"
                       Margin="0,2,0,0"/>

        </StackPanel>


        <!-- Settings panel -->
        <Border Grid.Row="1"
                Background="#252526"
                BorderBrush="#3F3F46"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,10">

            <Grid>
                
                <Grid.ColumnDefinitions>
                    
                    <ColumnDefinition Width="135"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>

                </Grid.RowDefinitions>

                <!-- Delay mode -->
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="Delay mode:"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <ComboBox Grid.Row="0"
                          Grid.Column="1"
                          Height="28"
                          ItemsSource="{Binding DelayModes}"
                          SelectedItem="{Binding SelectedDelayMode}"
                          IsEnabled="{Binding CanEditSettings}"
                          Background="White"
                          Foreground="#1E1E1E"/>

                <!-- Number of events -->
                <TextBlock Grid.Row="0"
                           Grid.Column="3"
                           Text="Events:"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Row="0"
                         Grid.Column="4"
                         Height="28"
                         MaxLength="4"
                         Text="{Binding NumberOfEvents, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding CanEditSettings}"
                         Background="White"
                         Foreground="#1E1E1E"
                         Padding="6,3"
                         PreviewTextInput="DigitsOnly_PreviewTextInput"
                         PreviewKeyDown="NumberTextBox_PreviewKeyDown"
                         DataObject.Pasting="DigitsOnly_Pasting"/>

                <!-- Global PIN -->
                <TextBlock Grid.Row="0"
                           Grid.Column="6"
                           Text="Global PIN:"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <TextBox Grid.Row="0"
                         Grid.Column="7"
                         Height="28"
                         MaxLength="5"
                         Text="{Binding GlobalPin, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding CanEditSettings}"
                         Background="White"
                         Foreground="#1E1E1E"
                         Padding="6,3"/>

                <!-- Delay values -->
                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="Delay range:"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Row="2"
                            Grid.Column="1"
                            Orientation="Horizontal">

                    <TextBox Width="65"
                             Height="28"
                             MaxLength="3"
                             Text="{Binding MinimumDelaySeconds, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding CanEditCustomDelay}"
                             Background="White"
                             Foreground="#1E1E1E"
                             Padding="6,3"
                             PreviewTextInput="DigitsOnly_PreviewTextInput"
                             PreviewKeyDown="NumberTextBox_PreviewKeyDown"
                             DataObject.Pasting="DigitsOnly_Pasting"/>

                    <TextBlock Text=" to "
                               Foreground="#CCCCCC"
                               VerticalAlignment="Center"
                               Margin="6,0"/>

                    <TextBox Width="65"
                             Height="28"
                             MaxLength="3"
                             Text="{Binding MaximumDelaySeconds, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding CanEditCustomDelay}"
                             Background="White"
                             Foreground="#1E1E1E"
                             Padding="6,3"
                             PreviewTextInput="DigitsOnly_PreviewTextInput"
                             PreviewKeyDown="NumberTextBox_PreviewKeyDown"
                             DataObject.Pasting="DigitsOnly_Pasting"/>

                    <TextBlock Text=" sec"
                               Foreground="#CCCCCC"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0"/>

                </StackPanel>

                <!-- Event profile -->
                <TextBlock Grid.Row="2"
                           Grid.Column="3"
                           Text="Profile:"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <ComboBox Grid.Row="2"
                          Grid.Column="4"
                          Grid.ColumnSpan="4"
                          Height="28"
                          ItemsSource="{Binding EventProfiles}"
                          SelectedItem="{Binding SelectedEventProfile}"
                          IsEnabled="{Binding CanEditSettings}"
                          Background="White"
                          Foreground="#1E1E1E"/>

                <!-- Validation message -->
                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Grid.ColumnSpan="8"
                           Text="{Binding ValidationMessage}"
                           Foreground="#E6AA28"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"/>

            </Grid>

        </Border>


        <!-- Controls and running summary -->
        <Border Grid.Row="2"
                Background="#252526"
                BorderBrush="#3F3F46"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,10">

            <Grid>
                
                <Grid.ColumnDefinitions>
                    
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                    
                </Grid.ColumnDefinitions>

                <!-- Buttons -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Button Content="Start"
                            Width="70"
                            Height="32"
                            Command="{Binding StartSimulationCommand}"/>

                    <Button Content="Stop"
                            Width="70"
                            Height="32"
                            Margin="8,0,0,0"
                            Command="{Binding StopSimulationCommand}"/>

                    <Button Content="Clear"
                            Width="70"
                            Height="32"
                            Margin="8,0,0,0"
                            Command="{Binding ClearLogCommand}"/>

                </StackPanel>

                <!-- Summary -->
                <Grid Grid.Column="2">

                    <Grid.RowDefinitions>

                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="Auto"/>

                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal">

                        <TextBlock Text="Status: "
                                   Foreground="White"
                                   FontWeight="Bold"/>

                        <TextBlock Text="{Binding SimulationStatus}"
                                   Foreground="#CCCCCC"
                                   Margin="0,0,18,0"/>

                        <TextBlock Text="Requested: "
                                   Foreground="White"
                                   FontWeight="Bold"/>

                        <TextBlock Text="{Binding NumberOfEvents}"
                                   Foreground="#CCCCCC"
                                   Margin="0,0,18,0"/>

                        <TextBlock Text="Completed: "
                                   Foreground="White"
                                   FontWeight="Bold"/>

                        <TextBlock Text="{Binding CompletedEvents}"
                                   Foreground="#CCCCCC"
                                   Margin="0,0,18,0"/>

                        <TextBlock Text="Retries: "
                                   Foreground="White"
                                   FontWeight="Bold"/>

                        <TextBlock Text="{Binding FailedAttempts}"
                                   Foreground="#CCCCCC"/>

                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal">

                        <TextBlock Text="Profile:     "
                                   Foreground="White"
                                   FontWeight="Bold"/>

                        <TextBlock Text="{Binding NormalEventPercentage, StringFormat=Normal {0}%}"
                                   Foreground="#CCCCCC"
                                   Margin="0,0,12,0"/>

                        <TextBlock Text="{Binding ForcedEventPercentage, StringFormat=Forced {0}%}"
                                   Foreground="#CCCCCC"
                                   Margin="0,0,12,0"/>

                        <TextBlock Text="{Binding HeldEventPercentage, StringFormat=Held {0}%}"
                                   Foreground="#CCCCCC"/>

                    </StackPanel>

                    <StackPanel Grid.Row="4"
                                Orientation="Horizontal">

                        <TextBlock Text="Executed: "
                                   Foreground="White"
                                   FontWeight="Bold"/>

                        <TextBlock Text="{Binding ExecutedNormalEvents, StringFormat=Normal {0}}"
                                   Foreground="#CCCCCC"
                                   Margin="0,0,12,0"/>

                        <TextBlock Text="{Binding ExecutedForcedEvents, StringFormat=Forced {0}}"
                                   Foreground="#CCCCCC"
                                   Margin="0,0,12,0"/>

                        <TextBlock Text="{Binding ExecutedHeldEvents, StringFormat=Held {0}}"
                                   Foreground="#CCCCCC"/>

                    </StackPanel>

                </Grid>
                
            </Grid>

        </Border>


        <!-- Event log -->
        <Border Grid.Row="3"
                Background="#111111"
                BorderBrush="#3F3F46"
                BorderThickness="1"
                CornerRadius="6"
                Padding="8">

            <Grid>
                
                <Grid.RowDefinitions>
                    
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Event Log"
                           Foreground="White"
                           FontWeight="Bold"
                           FontSize="14"
                           Margin="0,0,0,8"/>

                <ListView Grid.Row="1"
                          ItemsSource="{Binding LogEntries}"
                          Background="#111111"
                          Foreground="#CCCCCC"
                          BorderThickness="0"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">

                    <ListView.View>
                        
                        <GridView>
                            
                            <GridViewColumn Header="Time"
                                            Width="70"
                                            DisplayMemberBinding="{Binding TimeText}"/>

                            <GridViewColumn Header="Event"
                                            Width="75"
                                            DisplayMemberBinding="{Binding EventText}"/>

                            <GridViewColumn Header="Level"
                                            Width="80">
                                
                                <GridViewColumn.CellTemplate>
                                    
                                    <DataTemplate>
                                        
                                        <TextBlock Text="{Binding Level}"
                                                   Foreground="{Binding LevelBrush}"
                                                   FontWeight="SemiBold"/>
                                    </DataTemplate>
                                    
                                </GridViewColumn.CellTemplate>
                                
                            </GridViewColumn>

                            <GridViewColumn Header="Type"
                                            Width="80"
                                            DisplayMemberBinding="{Binding EventType}"/>

                            <GridViewColumn Header="Door"
                                            Width="160"
                                            DisplayMemberBinding="{Binding DoorName}"/>

                            <GridViewColumn Header="Message"
                                            Width="320"
                                            DisplayMemberBinding="{Binding Message}"/>
                        </GridView>
                        
                    </ListView.View>

                </ListView>
                
            </Grid>

        </Border>

    </Grid>
    
</UserControl>