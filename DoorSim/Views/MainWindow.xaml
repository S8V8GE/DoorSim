<!--
        Main application window (View).

        Responsible for:
        - Overall layout of the application
        - Top navigation (Connect, View, Help, About)
        - Status display (connected / not connected)
        - Hosting the main content area (which will later show doors)

        This View binds to MainViewModel.cs, which controls all behaviour and state.
-->

<Window x:Class="DoorSim.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:DoorSim.ViewModels"
        xmlns:views="clr-namespace:DoorSim.Views"
        Title="DoorSim - Softwire Door Simulation &amp; Testing Tool"
        Height="800"
        MinHeight="800"
        MaxHeight="800"
        Width="800"
        MinWidth="800"
        MaxWidth="800"
        Background="#1E1E1E"
        Foreground="White"
        Icon="/Images/AppIcon.ico">


    <!--
        Local UI styling for this window.

        Defines:
        - Highlight colours (attempt to override default menu selection colours)
        - Basic MenuItem styling (background, text, borders)

        Note: WPF MenuItem styling is partially controlled by its template,
        so not all colour changes take effect here...
    -->

    <Window.Resources>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#005A9E"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#005A9E"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
        </Style>
    </Window.Resources>


    <!--
        Root layout container.

        DockPanel allows:
        - Top menu bar
        - Bottom status bar
        - Central content area filling remaining space
    -->
    <Border BorderBrush="#3F3F46"
        BorderThickness="1"
        Margin="6"
        Background="#1E1E1E">
        
        <DockPanel>

            <!--
                Top navigation menu.

                Contains:
                - Connect → triggers connection to Softwire
                - View → switches between single/two door views (enabled only when connected)
                - Help/About → informational views

                Visibility and behaviour controlled via MainViewModel bindings.
            -->
            <Border DockPanel.Dock="Top"
                    BorderBrush="#3F3F46"
                    BorderThickness="0,0,0,1">

                <Menu Background="#252526"
                      Foreground="White">

                    <!--
                        Connect command:
                        - Opens connection dialog
                        - Attempts login to Softwire
                        - Disabled once connected (CanConnect = false)
                    -->
                    <MenuItem Header="_Connect"
                              Command="{Binding ConnectCommand}"
                              IsEnabled="{Binding CanConnect}"/>

                    <!--
                        View selection:
                        - Will control layout of door simulation (single vs two door view)
                        - Only enabled when a valid Softwire connection exists
                    -->
                    <MenuItem Header="_View"
                              IsEnabled="{Binding IsConnected}">

                        <MenuItem Header="_Single Door"
                                  IsCheckable="True"
                                  IsChecked="{Binding IsSingleDoorViewSelected, Mode=OneWay}"
                                  Command="{Binding ShowSingleDoorViewCommand}"/>

                        <MenuItem Header="_Two Doors"
                                  IsCheckable="True"
                                  IsChecked="{Binding IsTwoDoorViewSelected, Mode=OneWay}"
                                  Command="{Binding ShowTwoDoorViewCommand}"/>

                    </MenuItem>

                    <MenuItem Header="_Help"/>
                    <MenuItem Header="_About"/>

                </Menu>
            </Border>

        
            <!--
                Status bar (bottom of application).

                Displays:
                - Current connection state (text)
                - Colour-coded status (green = connected, red = not connected)

                Driven entirely by MainViewModel bindings.
            -->
            <Border DockPanel.Dock="Bottom"
                    BorderBrush="#3F3F46"
                    BorderThickness="0,1,0,0">

                <StatusBar Background="#252526"
                           Foreground="White">

                    <!--
                        Status display:
                        - Text comes from StatusText
                        - Colour comes from StatusColor (dynamic)
                    -->
                    <StatusBarItem>
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{Binding StatusColor}"
                                   FontWeight="SemiBold"
                                   Margin="5,0,0,0"/>
                    </StatusBarItem>

                </StatusBar>
            </Border>


            <!--
                Main content area.

                Hosts either:
                - Single Door layout
                - Two Door layout

                The View menu controls which layout is visible.
            -->
            <Grid>

                <!--
                    Single Door layout.

                    Contains:
                    - One door selector
                    - One fully interactive SingleDoorView
                    - Shared cardholders panel
                -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>

                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSingleDoorViewSelected}"
                                             Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="220"/>
                    </Grid.RowDefinitions>

                    <!-- Door selector bar -->
                    <views:DoorSelectorView Grid.Row="0"
                                            DataContext="{Binding Doors}">
                        <views:DoorSelectorView.Style>
                            <Style TargetType="views:DoorSelectorView">
                                <Setter Property="Visibility" Value="Collapsed"/>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsConnected, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </views:DoorSelectorView.Style>
                    </views:DoorSelectorView>

                    <!-- Door display area -->
                    <Grid Grid.Row="1">

                        <TextBlock Text="{Binding MainMessage}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="22"
                                   Foreground="#CCCCCC"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   MaxWidth="850"/>

                        <views:SingleDoorView DataContext="{Binding Doors}">
                            <views:SingleDoorView.Style>
                                <Style TargetType="views:SingleDoorView">
                                    <Setter Property="Visibility" Value="Collapsed"/>

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSelectedDoor}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </views:SingleDoorView.Style>
                        </views:SingleDoorView>

                    </Grid>

                    <!-- Cardholders panel -->
                    <views:CardholdersView Grid.Row="2"
                                           DataContext="{Binding Cardholders}">
                        <views:CardholdersView.Style>
                            <Style TargetType="views:CardholdersView">
                                <Setter Property="Visibility" Value="Collapsed"/>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsConnected, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </views:CardholdersView.Style>
                    </views:CardholdersView>
                </Grid>


                <!--
                    Two Door layout.

                    Placeholder for now. Later this will contain:
                    - Door selector and simulator panel for Door 1
                    - Door selector and simulator panel for Door 2
                    - Shared cardholder panel / interlocking controls
                -->
                <views:TwoDoorView DataContext="{Binding TwoDoor}">
                    <views:TwoDoorView.Style>
                        <Style TargetType="views:TwoDoorView">
                            <Setter Property="Visibility" Value="Collapsed"/>

                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsTwoDoorViewSelected, RelativeSource={RelativeSource AncestorType=Window}}"
                                             Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </views:TwoDoorView.Style>
                </views:TwoDoorView>

            </Grid>

        </DockPanel>
        
    </Border>
    
</Window>