<UserControl x:Class="DoorSim.Views.DoorPanelSelectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:DoorSim.Views"
             Background="#1E1E1E"
             Foreground="White">

<!--
    Door selector for one reusable door panel in Two Door View.

    Expected DataContext:
        - DoorPanelViewModel

    Responsibilities:
        - Show the number of doors available to this panel.
        - Let the trainer select the door for this side of Two Door View.
        - Show placeholder text when no door is selected.

    Note: This intentionally looks like DoorSelectorView, but binds to DoorPanelViewModel instead of DoorsViewModel so the left and right panels can maintain independent selections.
-->
    <Border Background="#1F3A5F"
            BorderBrush="#3F3F46"
            BorderThickness="0,0,0,1"
            Padding="8,4">

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <TextBlock Text="{Binding DoorSelectorTitle}"
                       FontWeight="SemiBold"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>

            <!--
                Searchable door selector.

                Uses SearchableSelectorView instead of an editable ComboBox so search text
                never changes SelectedDoor. SelectedDoor only changes when the trainer
                selects a result.

                In Two Door View, the ItemsSource is already filtered by TwoDoorViewModel
                so the same door cannot be selected on both sides.
            -->
            <views:SearchableSelectorView Width="300"
                                          Height="28"
                                          ItemsSource="{Binding Doors}"
                                          SelectedItem="{Binding SelectedDoor, Mode=TwoWay}"
                                          DisplayMemberPath="Name"
                                          PlaceholderText="Select a door"/>

        </StackPanel>
        
    </Border>
    
</UserControl>