<UserControl x:Class="DoorSim.Views.DoorSelectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:DoorSim.Views"
             Background="#1E1E1E"
             Foreground="White">

    <!--
        Single Door selector bar.

        Expected DataContext:
            - DoorsViewModel

        Responsibilities:
            - Show the number of doors loaded from Softwire.
            - Let the user select the active door for Single Door View.
            - Show placeholder text when no door is selected.

        Note: Two Door View uses DoorPanelSelectorView instead, because each side binds to a DoorPanelViewModel rather than directly to DoorsViewModel.
    -->
    <Border Background="#1F3A5F"
            BorderBrush="#3F3F46"
            BorderThickness="0,0,0,1"
            Padding="8,4">

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <TextBlock Text="{Binding DoorCount, StringFormat='Select a door ({0}):'}"
                       FontWeight="SemiBold"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>

            <!--
                Searchable door selector.

                Uses SearchableSelectorView instead of an editable ComboBox so search text
                never changes SelectedDoor. SelectedDoor only changes when the trainer
                selects a result.
            -->
            <views:SearchableSelectorView Width="300"
                                          Height="28"
                                          ItemsSource="{Binding Doors}"
                                          SelectedItem="{Binding SelectedDoor, Mode=TwoWay}"
                                          DisplayMemberPath="Name"
                                          PlaceholderText="Select a door"/>

        </StackPanel>
        
    </Border>
    
</UserControl>