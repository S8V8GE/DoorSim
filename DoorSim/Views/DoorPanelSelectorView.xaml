<UserControl x:Class="DoorSim.Views.DoorPanelSelectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E"
             Foreground="White">

    <!--
        Door selector for one reusable door panel.

        Unlike DoorSelectorView, this binds to DoorPanelViewModel.
        That allows TwoDoorView to have:
        - one selector for the left door panel
        - one selector for the right door panel

        Each selector owns its own SelectedDoor.
    -->

    <Border Background="#1F3A5F"
            Padding="10,6">

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <TextBlock Text="{Binding DoorSelectorTitle}"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <ComboBox ItemsSource="{Binding Doors}"
                      SelectedItem="{Binding SelectedDoor, Mode=TwoWay}"
                      DisplayMemberPath="Name"
                      Width="270"
                      Height="28"/>
            
        </StackPanel>

    </Border>
    
</UserControl>