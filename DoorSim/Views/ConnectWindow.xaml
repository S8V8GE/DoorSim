<Window x:Class="DoorSim.Views.ConnectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connect to Softwire"
        Height="260"
        Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E"
        Foreground="White"
        Icon="/Images/AppIcon.ico">

<!--
    Connection dialog (View).

    Responsible for:
        - Collecting Softwire connection details (hostname + password)
        - Allowing the user to initiate a connection
        - Returning entered values to the MainViewModel using DialogResult

    This window does NOT perform the connection itself. It simply gathers input and signals OK/Cancel.
-->

    <!--
        Styled container for the dialog.

        Provides:
            - Subtle border outline
            - Rounded corners
            - Padding for consistent spacing

        Used to create a modern, non-default WPF dialog appearance.
    -->
    <Border BorderBrush="#3F3F46"
            BorderThickness="1"
            CornerRadius="6"
            Padding="20"
            Background="#1E1E1E">

        <!--
            Grid layout for form structure.

            Uses rows to:
                - Align labels and inputs vertically
                - Provide consistent spacing between elements
        -->
        <Grid>
            
            <Grid.RowDefinitions>
                
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                
            </Grid.RowDefinitions>

            <!--
                Hostname input:
                    - User enters Softwire server address
                    - Defaults to localhost for training/lab environments
            -->
            <TextBlock Text="Softwire Hostname:"
                       FontWeight="Bold"
                       Foreground="#CCCCCC"/>

            <TextBox Grid.Row="2"
                     x:Name="HostnameTextBox"
                     Text="127.0.0.1"
                     Background="#2D2D30"
                     Foreground="White"
                     BorderBrush="#555555"
                     Padding="6"/>

            <!--
                Password input:
                    - Secure entry using PasswordBox
                    - Used for Softwire authentication
            -->
            <TextBlock Grid.Row="4"
                       Text="Softwire Password:"
                       FontWeight="Bold"
                       Foreground="#CCCCCC"/>

            <!--
                Password visibility toggle.

                Contains:
                    - PasswordBox (hidden text)
                    - TextBox (visible text)
                    - Button to temporarily reveal password

                Behaviour:
                    - Press and hold (MouseDown) → password visible
                    - Release (MouseUp or MouseLeave) → password hidden again
            -->
            <Grid Grid.Row="6">
                
                <Grid.ColumnDefinitions>
                    
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    
                </Grid.ColumnDefinitions>

                <PasswordBox x:Name="PasswordBox"
                             PasswordChar="●"
                             Background="#2D2D30"
                             Foreground="White"
                             BorderBrush="#555555"
                             Padding="6"/>

                <TextBox x:Name="PasswordTextBox"
                         Visibility="Collapsed"
                         Background="#2D2D30"
                         Foreground="White"
                         BorderBrush="#555555"
                         Padding="6"/>

                <!--
                    "Hold to view password" button.

                    Uses mouse events:
                        - MouseDown → show password
                        - MouseUp / MouseLeave → hide password
                -->
                <Button Grid.Column="2"
                        Content="👁"
                        Width="50"
                        ToolTip="Hold to view password"
                        Background="#3A3A3D"
                        Foreground="White"
                        BorderBrush="#555555"
                        PreviewMouseDown="ViewPassword_MouseDown"
                        PreviewMouseUp="ViewPassword_MouseUp"
                        MouseLeave="ViewPassword_MouseUp"/>
                
            </Grid>

            <!--
                Action buttons:

                Cancel:
                    - Closes dialog without connecting

                Connect:
                    - Confirms input and returns control to MainViewModel
            -->
            <StackPanel Grid.Row="8"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <Button Content="Cancel"
                        Width="80"
                        Margin="0,0,10,0"
                        Background="#3A3A3D"
                        Foreground="White"
                        BorderBrush="#555555"
                        Padding="6"
                        IsCancel="True"
                        Click="Cancel_Click"/>

                <!--
                    Primary action:
                        - Triggers connection attempt via MainViewModel
                        - Marked as default (Enter key activates it)
                -->
                <Button Content="Connect"
                        Width="80"
                        Background="#007ACC"
                        Foreground="White"
                        BorderBrush="#007ACC"
                        Padding="6"
                        IsDefault="True"
                        Click="Connect_Click"/>
                
            </StackPanel>
            
        </Grid>
        
    </Border>
    
</Window>