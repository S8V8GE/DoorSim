<UserControl x:Class="DoorSim.Views.AutoModeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="300">

    <!--
        Auto Mode page.

        This is intentionally only a placeholder for now.
        The first step is to safely wire app mode switching without disturbing
        the existing Manual Mode / Single Door / Two Door functionality.
    -->

    <Grid Background="#1E1E1E"
          Margin="20">

        <Border Background="#252526"
                BorderBrush="#3F3F46"
                BorderThickness="1"
                CornerRadius="8"
                Padding="24"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">

            <Grid>
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            MaxWidth="720">

                    <TextBlock Text="{Binding Title}"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="{Binding Subtitle}"
                               FontSize="16"
                               Foreground="#CCCCCC"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="{Binding PlaceholderMessage}"
                               FontSize="18"
                               Foreground="#AAAAAA"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"/>

                </StackPanel>
            </Grid>

        </Border>
    </Grid>
</UserControl>