<UserControl x:Class="DoorSim.Views.DoorPanelSelectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E"
             Foreground="White">

<!--
    Door selector for one reusable door panel in Two Door View.

    Expected DataContext:
        - DoorPanelViewModel

    Responsibilities:
        - Show the number of doors available to this panel.
        - Let the trainer select the door for this side of Two Door View.
        - Show placeholder text when no door is selected.

    Note: This intentionally looks like DoorSelectorView, but binds to DoorPanelViewModel instead of DoorsViewModel so the left and right panels can maintain independent selections.
-->
    <Border Background="#1F3A5F"
            BorderBrush="#3F3F46"
            BorderThickness="0,0,0,1"
            Padding="8,4">

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <TextBlock Text="{Binding DoorSelectorTitle}"
                       FontWeight="SemiBold"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>

            <!--
                ComboBox wrapper.

                The Grid allows placeholder text to be layered over the ComboBox when SelectedDoor is null.
            -->
            <Grid Width="300"
                  Height="28">

                <ComboBox ItemsSource="{Binding Doors}"
                          SelectedItem="{Binding SelectedDoor, Mode=TwoWay}"
                          DisplayMemberPath="Name"
                          MaxDropDownHeight="260"
                          Background="White"
                          Foreground="#1E1E1E"
                          BorderBrush="#555555"
                          Padding="6"
                          FontWeight="SemiBold"
                          HorizontalContentAlignment="Left"
                          VerticalContentAlignment="Center"/>

                <!-- Placeholder text shown when no door is selected -->
                <TextBlock Text="Select a door"
                           Foreground="#666666"
                           FontWeight="SemiBold"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False">

                    <TextBlock.Style>
                        
                        <Style TargetType="TextBlock">
                            
                            <Setter Property="Visibility" Value="Collapsed"/>

                            <Style.Triggers>
                                
                                <DataTrigger Binding="{Binding SelectedDoor}"
                                             Value="{x:Null}">
                                    
                                    <Setter Property="Visibility" Value="Visible"/>
                                    
                                </DataTrigger>
                                
                            </Style.Triggers>
                            
                        </Style>
                        
                    </TextBlock.Style>

                </TextBlock>
                
            </Grid>

        </StackPanel>
        
    </Border>
    
</UserControl>