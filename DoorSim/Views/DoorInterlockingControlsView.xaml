<UserControl x:Class="DoorSim.Views.DoorInterlockingControlsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:DoorSim.Views"
             Background="#1E1E1E"
             Foreground="White">

    <!--
    Door interlocking controls panel.

    This intentionally matches the visual structure of CardholdersView:
    - Outer Grid
    - Border with Margin=10 and Padding=10
    - Blue title bar
    - 10px spacer
    - Content area

    Later this will contain:
    - Override input selector
    - Lockdown input selector
    -->

    <Grid>

        <Border BorderBrush="#3F3F46"
                BorderThickness="1"
                Background="#1E1E1E"
                Margin="10"
                Padding="10">

            <Grid>
                
                <Grid.RowDefinitions>
                    
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                    
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Border Grid.Row="0"
                        Background="#1F3A5F"
                        Padding="10,6"
                        MinHeight="42">

                    <DockPanel LastChildFill="False">

                        <StackPanel Orientation="Horizontal"
                                    DockPanel.Dock="Left"
                                    VerticalAlignment="Center">

                            <TextBlock Text="🔒 Door Interlocking Controls"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                    </DockPanel>
                    
                </Border>

                <!-- Interlocking input controls -->
                <Grid Grid.Row="2"
                      Background="#1E1E1E"
                      Margin="10,6,10,0">

                    <!--
                        Two compact stacked rows:
                        - Override section
                        - Lockdown section

                        Each section contains:
                        - Label
                        - Searchable selector
                        - Normal / Active buttons
                        - Status text directly below the selector
                    -->
                    <Grid.RowDefinitions>
                        
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        
                    </Grid.RowDefinitions>

                    <!-- ========================= OVERRIDE SECTION ========================= -->
                    <Grid Grid.Row="0">

                        <Grid.ColumnDefinitions>
                            
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="310"/>
                            <ColumnDefinition Width="105"/>
                            <ColumnDefinition Width="105"/>
                            
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            
                        </Grid.RowDefinitions>

                        <!-- Override label -->
                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="Override Input:"
                                   FontSize="16"
                                   Foreground="#CCCCCC"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>

                        <!-- Override selector -->
                        <views:SearchableSelectorView Grid.Row="0"
                                                      Grid.Column="1"
                                                      Width="300"
                                                      Height="28"
                                                      ItemsSource="{Binding AvailableOverrideInputs}"
                                                      SelectedItem="{Binding OverrideInput, Mode=TwoWay}"
                                                      DisplayMemberPath="DisplayName"
                                                      PlaceholderText="Select an input"/>

                        <!-- Override Normal button -->
                        <Button Grid.Row="0"
                                Grid.Column="2"
                                Content="Normal"
                                Width="92"
                                Height="34"
                                Margin="8,0,0,0"
                                Command="{Binding SetOverrideNormalCommand}"/>

                        <!-- Override Active button -->
                        <Button Grid.Row="0"
                                Grid.Column="3"
                                Content="Active"
                                Width="92"
                                Height="34"
                                Margin="8,0,0,0"
                                Command="{Binding SetOverrideActiveCommand}"/>

                        <!-- Override status text -->
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding OverrideStatusText}"
                                   Foreground="{Binding OverrideStatusColor}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Left"
                                   Margin="4,4,0,0"/>
                        
                    </Grid>

                    <!-- ========================= LOCKDOWN SECTION ========================= -->
                    <Grid Grid.Row="2">

                        <Grid.ColumnDefinitions>
                            
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="310"/>
                            <ColumnDefinition Width="105"/>
                            <ColumnDefinition Width="105"/>
                            
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            
                        </Grid.RowDefinitions>

                        <!-- Lockdown label -->
                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="Lockdown Input:"
                                   FontSize="16"
                                   Foreground="#CCCCCC"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>

                        <!-- Lockdown selector -->
                        <views:SearchableSelectorView Grid.Row="0"
                                                      Grid.Column="1"
                                                      Width="300"
                                                      Height="28"
                                                      ItemsSource="{Binding AvailableLockdownInputs}"
                                                      SelectedItem="{Binding LockdownInput, Mode=TwoWay}"
                                                      DisplayMemberPath="DisplayName"
                                                      PlaceholderText="Select an input"/>

                        <!-- Lockdown Normal button -->
                        <Button Grid.Row="0"
                                Grid.Column="2"
                                Content="Normal"
                                Width="92"
                                Height="34"
                                Margin="8,0,0,0"
                                Command="{Binding SetLockdownNormalCommand}"/>

                        <!-- Lockdown Active button -->
                        <Button Grid.Row="0"
                                Grid.Column="3"
                                Content="Active"
                                Width="92"
                                Height="34"
                                Margin="8,0,0,0"
                                Command="{Binding SetLockdownActiveCommand}"/>

                        <!-- Lockdown status text -->
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding LockdownStatusText}"
                                   Foreground="{Binding LockdownStatusColor}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Left"
                                   Margin="4,4,0,0"/>
                        
                    </Grid>

                </Grid>

            </Grid>
            
        </Border>
        
    </Grid>
    
</UserControl>