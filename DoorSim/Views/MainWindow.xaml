<!--
    Main application window.

    Responsible for:
        - Overall application shell layout
        - Top navigation menu
        - Status bar
        - Hosting Manual Mode views and Auto Mode
        - Switching between Single Door, Two Door, and Auto Mode content

    Behaviour and state are provided by MainViewModel.
-->

<Window x:Class="DoorSim.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:DoorSim.ViewModels"
        xmlns:views="clr-namespace:DoorSim.Views"
        Title="DoorSim - Softwire Door Simulation &amp; Testing Tool"
        Height="800"
        MinHeight="800"
        MaxHeight="800"
        Width="800"
        MinWidth="800"
        MaxWidth="800"
        Background="#1E1E1E"
        Foreground="White"
        Icon="/Images/AppIcon.ico">


    <!--
        Window-level styling / Local UI styling for this window.

        Defines:
            - Selection highlight brushes used by WPF menu controls
            - Basic dark MenuItem styling
    -->

    <Window.Resources>
        
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#005A9E"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#005A9E"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>

        <Style TargetType="MenuItem">
            
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            
        </Style>
        
    </Window.Resources>


    <!--
        Root layout container.

        DockPanel allows:
            - Top menu bar
            - Bottom status bar
            - Central content area filling remaining space
    -->
    <Border BorderBrush="#3F3F46"
            BorderThickness="1"
            Margin="6"
            Background="#1E1E1E">
        
        <DockPanel>

            <!--
                Top navigation menu.

                Contains:
                    - Connect → triggers connection to Softwire
                    - Mode → switches between Manual Mode and Auto Mode
                    - View → switches between Single Door and Two Door manual layouts
                    - Help/About → help guide and application information

                Visibility and behaviour controlled via MainViewModel bindings.
            -->
            <Border DockPanel.Dock="Top"
                    BorderBrush="#3F3F46"
                    BorderThickness="0,0,0,1">

                <Menu Background="#252526"
                      Foreground="White">

                    <!--
                        Connect command:
                            - Opens connection dialog
                            - Attempts login to Softwire
                            - Disabled once connected (CanConnect = false)
                    -->
                    <MenuItem Header="_Connect"
                              Command="{Binding ConnectCommand}"
                              IsEnabled="{Binding CanConnect}"/>

                    <!--    
                        Mode selection:
                            - Switches between Manual Mode and Auto Mode
                            - Shows a check mark beside the active mode
                    -->
                    <MenuItem Header="_Mode"
                              IsEnabled="{Binding CanUseModeMenu}">

                        <MenuItem Header="_Manual Mode"
                                  IsCheckable="True"
                                  IsChecked="{Binding IsManualModeSelected, Mode=OneWay}"
                                  Command="{Binding ShowManualModeCommand}"/>

                        <MenuItem Header="_Auto Mode"
                                  IsCheckable="True"
                                  IsChecked="{Binding IsAutoModeSelected, Mode=OneWay}"
                                  Command="{Binding ShowAutoModeCommand}"/>

                    </MenuItem>

                    <!--
                        View selection:
                            - Switches between Single Door and Two Door layouts
                            - Shows a check mark beside the active view
                            - Enabled only when connected to Softwire
                    -->
                    <MenuItem Header="_View"
                              IsEnabled="{Binding CanUseViewMenu}">

                        <MenuItem Header="_Single Door"
                                  IsCheckable="True"
                                  IsChecked="{Binding IsSingleDoorViewSelected, Mode=OneWay}"
                                  Command="{Binding ShowSingleDoorViewCommand}"/>

                        <MenuItem Header="_Two Doors"
                                  IsCheckable="True"
                                  IsChecked="{Binding IsTwoDoorViewSelected, Mode=OneWay}"
                                  Command="{Binding ShowTwoDoorViewCommand}"/>

                    </MenuItem>

                    <!-- Help/documentation and About window. -->
                    <MenuItem Header="_Help"
                              Click="HelpMenuItem_Click"/>
                    
                    <MenuItem Header="_About"
                              Click="AboutMenuItem_Click"/>

                </Menu>
                
            </Border>

        
            <!--
                Status bar (bottom of application).

                Displays:
                    - Current connection state (text)
                    - Colour-coded status (green = connected, red = not connected)

                Driven entirely by MainViewModel bindings.
            -->
            <Border DockPanel.Dock="Bottom"
                    BorderBrush="#3F3F46"
                    BorderThickness="0,1,0,0">

                <StatusBar Background="#252526"
                           Foreground="White">

                    <!--
                        Status display:
                            - Text comes from StatusText
                            - Colour comes from StatusColor (dynamic)
                    -->
                    <StatusBarItem>
                        
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{Binding StatusColor}"
                                   FontWeight="SemiBold"
                                   Margin="5,0,0,0"/>
                        
                    </StatusBarItem>

                </StatusBar>
                
            </Border>


            <!--
                Main content area.

                Hosts one of:
                    - Single Door manual layout
                    - Two Door manual layout
                    - Auto Mode layout

                The Mode menu controls Manual vs Auto.
                The View menu controls Single Door vs Two Door while in Manual Mode.
            -->
            <Grid>

                <!--
                    Single Door layout.

                    Contains:
                        - One door selector
                        - One fully interactive SingleDoorView
                        - Shared cardholders panel
                -->
                <Grid>

                    <Grid.Style>

                        <Style TargetType="Grid">

                            <Setter Property="Visibility" Value="Collapsed"/>

                            <Style.Triggers>

                                <!--
                                    Show Single Door layout only when:
                                        - app is in Manual Mode
                                        - Single Door View is selected
                                -->
                                <MultiDataTrigger>
                                    
                                    <MultiDataTrigger.Conditions>
                                        
                                        <Condition Binding="{Binding CurrentAppMode}"
                                                   Value="Manual"/>

                                        <Condition Binding="{Binding IsSingleDoorViewSelected}"
                                                   Value="True"/>
                                        
                                    </MultiDataTrigger.Conditions>

                                    <Setter Property="Visibility" Value="Visible"/>
                                    
                                </MultiDataTrigger>

                            </Style.Triggers>

                        </Style>

                    </Grid.Style>

                    <Grid.RowDefinitions>
                        
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="220"/>
                        
                    </Grid.RowDefinitions>

                    <!-- Door selector bar -->
                    <views:DoorSelectorView Grid.Row="0"
                                            DataContext="{Binding Doors}">
                        
                        <views:DoorSelectorView.Style>
                            
                            <Style TargetType="views:DoorSelectorView">
                                
                                <Setter Property="Visibility" Value="Collapsed"/>

                                <Style.Triggers>
                                    
                                    <DataTrigger Binding="{Binding DataContext.IsConnected, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="True">
                                        
                                        <Setter Property="Visibility" Value="Visible"/>
                                        
                                    </DataTrigger>
                                    
                                </Style.Triggers>
                                
                            </Style>
                            
                        </views:DoorSelectorView.Style>
                        
                    </views:DoorSelectorView>

                    <!-- Door display area - Shows MainMessage until a door is selected, then overlays the interactive SingleDoorView -->
                    <Grid Grid.Row="1">

                        <TextBlock Text="{Binding MainMessage}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="22"
                                   Foreground="#CCCCCC"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   MaxWidth="850"/>

                        <views:SingleDoorView DataContext="{Binding Doors}">
                            
                            <views:SingleDoorView.Style>
                                
                                <Style TargetType="views:SingleDoorView">
                                    
                                    <Setter Property="Visibility" Value="Collapsed"/>

                                    <Style.Triggers>
                                        
                                        <DataTrigger Binding="{Binding HasSelectedDoor}"
                                                     Value="True">
                                            
                                            <Setter Property="Visibility" Value="Visible"/>
                                            
                                        </DataTrigger>
                                        
                                    </Style.Triggers>
                                    
                                </Style>
                                
                            </views:SingleDoorView.Style>
                            
                        </views:SingleDoorView>

                    </Grid>

                    <!-- Cardholders panel -->
                    <views:CardholdersView Grid.Row="2"
                                           DataContext="{Binding Cardholders}">
                        
                        <views:CardholdersView.Style>
                            
                            <Style TargetType="views:CardholdersView">
                                
                                <Setter Property="Visibility" Value="Collapsed"/>

                                <Style.Triggers>
                                    
                                    <DataTrigger Binding="{Binding DataContext.IsConnected, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="True">
                                        
                                        <Setter Property="Visibility" Value="Visible"/>
                                        
                                    </DataTrigger>
                                    
                                </Style.Triggers>
                                
                            </Style>
                            
                        </views:CardholdersView.Style>
                        
                    </views:CardholdersView>
                    
                </Grid>


                <!--
                    Two Door layout.

                    Contains:
                        - Independent left/right door selector and simulator panels
                        - Shared cardholders panel
                        - Door interlocking controls area
                -->
                <views:TwoDoorView DataContext="{Binding TwoDoor}">

                    <views:TwoDoorView.Style>

                        <Style TargetType="views:TwoDoorView">

                            <Setter Property="Visibility" Value="Collapsed"/>

                            <Style.Triggers>

                                <!--
                                    Show Two Door layout only when:
                                        - app is in Manual Mode
                                        - Two Door View is selected
                                -->
                                <MultiDataTrigger>
                                    
                                    <MultiDataTrigger.Conditions>
                                        
                                        <Condition Binding="{Binding DataContext.CurrentAppMode, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   Value="Manual"/>

                                        <Condition Binding="{Binding DataContext.IsTwoDoorViewSelected, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   Value="True"/>
                                        
                                    </MultiDataTrigger.Conditions>

                                    <Setter Property="Visibility" Value="Visible"/>
                                    
                                </MultiDataTrigger>

                            </Style.Triggers>

                        </Style>

                    </views:TwoDoorView.Style>

                </views:TwoDoorView>

                <!--
                    Auto Mode layout.

                    Hosts the automated busy-site simulation controls, running summary, and event log. 
                    It is shown only when Mode > Auto Mode is selected.
                -->
                <views:AutoModeView DataContext="{Binding AutoMode}">

                    <views:AutoModeView.Style>

                        <Style TargetType="views:AutoModeView">

                            <Setter Property="Visibility" Value="Collapsed"/>

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding DataContext.CurrentAppMode, RelativeSource={RelativeSource AncestorType=Window}}"
                                             Value="Auto">

                                    <Setter Property="Visibility" Value="Visible"/>

                                </DataTrigger>

                            </Style.Triggers>

                        </Style>

                    </views:AutoModeView.Style>

                </views:AutoModeView>

            </Grid>

        </DockPanel>
        
    </Border>
    
</Window>