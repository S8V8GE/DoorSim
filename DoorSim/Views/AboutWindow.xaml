<Window x:Class="DoorSim.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About"
        Width="740"
        Height="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="White"
        Icon="/Images/AppIcon.ico">

    <!--
        DoorSim About window.

        Purpose:
        - Gives the app a more finished/product-like feel.
        - Clearly explains what DoorSim is and is not.
        - Provides version, author, feature summary, and support guidance.
    -->

    <Border BorderBrush="#3F3F46"
            BorderThickness="1"
            Background="#1E1E1E"
            Padding="22">

        <Grid>
            
            <Grid.RowDefinitions>
                
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0"
                       Text="About"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,18"/>

            <!-- Main content -->
            <Grid Grid.Row="1">
                
                <Grid.ColumnDefinitions>
                    
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                    
                </Grid.ColumnDefinitions>

                <!-- Left image area -->
                <Grid Grid.Column="0"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center">

                    <Image Source="/Images/DoorSim_About.png"
                           Width="175"
                           Height="175"
                           Stretch="Uniform"/>
                    
                </Grid>

                <!-- Right text content -->
                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center">

                    <TextBlock Text="DoorSim"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock Text="Softwire Door Simulation &amp; Testing Tool"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#CCCCCC"
                               Margin="0,2,0,14"/>

                    <Grid Margin="0,0,0,12">
                        
                        <Grid.ColumnDefinitions>
                            
                            <ColumnDefinition Width="85"/>
                            <ColumnDefinition Width="*"/>
                            
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="Version:"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="1"
                                   Text="v0.9 pre-release"
                                   Foreground="#CCCCCC"/>

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Text="Author:"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,4,0,0"/>

                        <StackPanel Grid.Row="1"
                                    Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,4,0,0">

                            <TextBlock Text="James Savage"
                                       Foreground="#CCCCCC"
                                       VerticalAlignment="Center"/>

                            <!-- LinkedIn profile link -->
                            <Button Width="20"
                                    Height="20"
                                    Margin="8,0,0,0"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip="www.linkedin.com/in/jamesdavidsavage"
                                    Click="LinkedInButton_Click">

                                <Image Source="/Images/LinkedIn.png"
                                       Width="16"
                                       Height="16"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       SnapsToDevicePixels="True"/>
                                
                            </Button>

                        </StackPanel>

                    </Grid>

                    <TextBlock Text="Disclaimer:"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock TextWrapping="Wrap"
                               Foreground="#CCCCCC"
                               Margin="0,2,0,12"
                               Text="DoorSim is an independent training/demo utility that interacts with Genetec Softwire simulation environments. It is not an official Genetec product, is not endorsed or supported by Genetec Inc., and is intended for local training and demonstration use only."/>

                    <TextBlock Text="About:"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock TextWrapping="Wrap"
                               Foreground="#CCCCCC"
                               Margin="0,2,0,12"
                               Text="DoorSim is a training/demo tool for interacting with Softwire simulated access control doors, including cardholders, readers, REX inputs, breakglass inputs, and interlocking scenarios."/>

                    <TextBlock Text="Support:"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock TextWrapping="Wrap"
                               Foreground="#CCCCCC"
                               Margin="0,2,0,0"
                               Text="For help, use the Help menu in DoorSim. To report bugs or request improvements, use the project’s GitHub Issues page."/>

                </StackPanel>
                
            </Grid>

            <!-- OK button -->
            <Button Grid.Row="2"
                    Content="OK"
                    Width="90"
                    Height="32"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0"
                    Click="OkButton_Click"/>

        </Grid>
        
    </Border>
    
</Window>