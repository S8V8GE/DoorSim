<UserControl x:Class="DoorSim.Views.SingleDoorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:DoorSim.Views"
             Background="#1E1E1E"
             Foreground="White">

    <Grid Margin="20">

        <!--
            Temporary hidden DoorPanelView.

            This proves the new reusable door panel control can be referenced by
            SingleDoorView before we begin moving the real door hardware UI into it.
            It stays hidden for now, so the existing working UI is not affected.
        -->
        <views:DoorPanelView DataContext="{Binding}"/>

    </Grid>
    
</UserControl>