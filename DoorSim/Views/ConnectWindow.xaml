<Window x:Class="DoorSim.Views.ConnectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connect to Softwire"
        Height="260"
        Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E"
        Foreground="White">

    <Border BorderBrush="#3F3F46"
            BorderThickness="1"
            CornerRadius="6"
            Padding="20"
            Background="#1E1E1E">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Softwire Hostname:"
                       FontWeight="Bold"
                       Foreground="#CCCCCC"/>

            <TextBox Grid.Row="2"
                     x:Name="HostnameTextBox"
                     Text="127.0.0.1"
                     Background="#2D2D30"
                     Foreground="White"
                     BorderBrush="#555555"
                     Padding="6"/>

            <TextBlock Grid.Row="4"
                       Text="Softwire Password:"
                       FontWeight="Bold"
                       Foreground="#CCCCCC"/>

            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <PasswordBox x:Name="PasswordBox"
                             PasswordChar="●"
                             Background="#2D2D30"
                             Foreground="White"
                             BorderBrush="#555555"
                             Padding="6"/>

                <TextBox x:Name="PasswordTextBox"
                         Visibility="Collapsed"
                         Background="#2D2D30"
                         Foreground="White"
                         BorderBrush="#555555"
                         Padding="6"/>

                <Button Grid.Column="2"
                        Content="👁"
                        Width="50"
                        ToolTip="Hold to view password"
                        Background="#3A3A3D"
                        Foreground="White"
                        BorderBrush="#555555"
                        PreviewMouseDown="ViewPassword_MouseDown"
                        PreviewMouseUp="ViewPassword_MouseUp"
                        MouseLeave="ViewPassword_MouseUp"/>
            </Grid>

            <StackPanel Grid.Row="8"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <Button Content="Cancel"
                        Width="80"
                        Margin="0,0,10,0"
                        Background="#3A3A3D"
                        Foreground="White"
                        BorderBrush="#555555"
                        Padding="6"
                        Click="Cancel_Click"/>

                <Button Content="Connect"
                        Width="80"
                        Background="#007ACC"
                        Foreground="White"
                        BorderBrush="#007ACC"
                        Padding="6"
                        IsDefault="True"
                        Click="Connect_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>