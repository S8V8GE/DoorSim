<Window x:Class="DoorSim.Views.PinEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enter PIN"
        Height="260"
        Width="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="White"
        Icon="/Images/AppIcon.ico">

    <Border BorderBrush="#3F3F46"
            BorderThickness="1"
            Padding="20"
            Background="#1E1E1E">

        <StackPanel>

            <!-- Dialog title -->
            <TextBlock Text="{Binding ReaderName}"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#CCCCCC"
                       Margin="0,0,0,12"/>

            <!-- Instruction text -->
            <TextBlock Text="Enter a 4 or 5 digit PIN."
                       Foreground="#CCCCCC"
                       Margin="0,0,0,10"/>

            <!-- PIN input with show/hide button -->
            <Grid>
                <PasswordBox x:Name="PinPasswordBox"
                 Height="32"
                 FontSize="16"
                 MaxLength="5"
                 Background="#2D2D30"
                 Foreground="White"
                 BorderBrush="#555555"
                 Padding="6,6,34,6"
                 PasswordChanged="PinPasswordBox_PasswordChanged"/>

                <TextBox x:Name="VisiblePinTextBox"
                         Height="32"
                         FontSize="16"
                         MaxLength="5"
                         Background="#2D2D30"
                         Foreground="White"
                         BorderBrush="#555555"
                         Padding="6,6,34,6"
                         Visibility="Collapsed"
                         TextChanged="VisiblePinTextBox_TextChanged"/>

                <Button x:Name="TogglePinVisibilityButton"
                        Content="👁"
                        Width="28"
                        Height="24"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,4,0"
                        Padding="0"
                        Click="TogglePinVisibilityButton_Click"/>
            </Grid>

            <!-- Validation message -->
            <TextBlock x:Name="ValidationText"
                       Text="PIN must be 4 or 5 digits."
                       Foreground="#FFAA00"
                       FontSize="12"
                       Margin="0,6,0,0"
                       Visibility="Collapsed"/>

            <!-- Countdown / timing message. Later this will be driven by the reader Card + PIN timeout from Softwire. -->
            <TextBlock x:Name="TimerText"
                       Text="Time remaining: -- seconds"
                       Foreground="#CCCCCC"
                       FontSize="12"
                       Margin="0,4,0,0"
                       Visibility="Collapsed"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">

                <Button Content="Cancel"
                        Width="80"
                        Margin="0,0,8,0"
                        IsCancel="True"
                        Click="CancelButton_Click"/>

                <Button x:Name="OkButton"
                        Content="Send PIN"
                        Width="80"
                        IsDefault="True"
                        IsEnabled="False"
                        Click="OkButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>