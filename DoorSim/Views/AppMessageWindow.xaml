<Window x:Class="DoorSim.Views.AppMessageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Message"
        Width="420"
        Height="190"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="White"
        Icon="/Images/AppIcon.ico">

    <Border BorderBrush="#3F3F46"
            BorderThickness="1"
            Padding="20"
            Background="#1E1E1E">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="MessageText"
                       Grid.Row="0"
                       TextWrapping="Wrap"
                       Foreground="#CCCCCC"
                       FontSize="14"
                       VerticalAlignment="Center"/>

            <Button Grid.Row="1"
                    Content="OK"
                    Width="90"
                    Height="30"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0"
                    IsDefault="True"
                    IsCancel="True"
                    Click="OkButton_Click"/>
        </Grid>
    </Border>
</Window>