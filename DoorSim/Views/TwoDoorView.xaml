<UserControl x:Class="DoorSim.Views.TwoDoorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:DoorSim.Views"
             Background="#1E1E1E"
             Foreground="White">

    <!--
    Two Door View.

    This will eventually contain two independent door simulators:
    - Left door selector + door panel
    - Right door selector + door panel
    - Shared interlocking controls

    For this first layout step, both panels still use the existing DoorsViewModel,
    so they will show the same selected door. That is expected for now.
    -->

    <Grid Background="#1E1E1E">

        <Grid.RowDefinitions>
            
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
            
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
            
        </Grid.ColumnDefinitions>


        <!--
            LEFT DOOR AREA
        -->
        <Grid Grid.Row="0"
              Grid.Column="0">

            <Grid.RowDefinitions>
                
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                
            </Grid.RowDefinitions>

            <!-- Left door selector.
                 Currently uses the existing shared DoorsViewModel. -->
            <views:DoorSelectorView Grid.Row="0"
                                    DataContext="{Binding Doors}"/>

            <!-- Left interactive door panel.
                 Currently mirrors the existing selected door. -->
            <views:DoorPanelView Grid.Row="1"
                                 DataContext="{Binding Doors}"
                                 Margin="20"/>

        </Grid>


        <!--
            RIGHT DOOR AREA
        -->
        <Grid Grid.Row="0"
              Grid.Column="2">

            <Grid.RowDefinitions>
                
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                
            </Grid.RowDefinitions>

            <!-- Right door selector.
                 Currently uses the existing shared DoorsViewModel. -->
            <views:DoorSelectorView Grid.Row="0"
                                    DataContext="{Binding Doors}"/>

            <!-- Right interactive door panel.
                 Currently mirrors the existing selected door. -->
            <views:DoorPanelView Grid.Row="1"
                                 DataContext="{Binding Doors}"
                                 Margin="20"/>

        </Grid>


        <!--
            Bottom left area:
            Shared cardholder list.

            Cardholders are shared across both door panels so the trainer can drag
            the same credential onto any of the four readers.
        -->
        <views:CardholdersView Grid.Row="1"
                               Grid.Column="0"
                               DataContext="{Binding Cardholders}"/>

        <!--
            Bottom right area:
            Two Door-specific controls.

            This will later contain:
            - Door interlocking ON/OFF
            - Override input selector
            - Lockdown input selector
        -->
        <views:DoorInterlockingControlsView Grid.Row="1"
                                            Grid.Column="2"/>

    </Grid>
    
</UserControl>