<UserControl x:Class="DoorSim.Views.TwoDoorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:DoorSim.Views"
             Background="#1E1E1E"
             Foreground="White">

    <!--
        Two Door View.

        Hosts two independent reusable door panels side by side:
            - Left selector + left interactive door panel
            - Right selector + right interactive door panel

        The bottom row contains:
            - Shared cardholder list
            - Door interlocking controls

        DataContext:
            - TwoDoorViewModel
-->

    <!--
        Root layout.

        Row 0:
            - Left and right door simulators

        Row 1:
            - Cardholders panel
            - Door interlocking controls

        Column 1 is a fixed spacer between the two sides.
    -->

    <Grid Background="#1E1E1E">

        <Grid.RowDefinitions>
            
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
            
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>  <!-- Centre gap between door panels -->
            <ColumnDefinition Width="*"/>
            
        </Grid.ColumnDefinitions>


        <!--
            ##################### LEFT DOOR AREA #####################
        
                - The selector binds to LeftDoorPanel.
                - The interactive panel binds to LeftDoorPanel.DoorState.
        -->
        <Grid Grid.Row="0"
              Grid.Column="0">

            <Grid.RowDefinitions>
                
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                
            </Grid.RowDefinitions>

            <!-- Left door selector. -->
            <views:DoorPanelSelectorView Grid.Row="0"
                                         DataContext="{Binding LeftDoorPanel}"/>

            <!-- Left interactive door panel. -->
            <views:DoorPanelView Grid.Row="1"
                                 DataContext="{Binding LeftDoorPanel.DoorState}"
                                 Margin="20"/>

        </Grid>


        <!--
            ##################### RIGHT DOOR AREA #####################
        
                - The selector binds to RightDoorPanel.
                - The interactive panel binds to RightDoorPanel.DoorState.
        -->
        <Grid Grid.Row="0"
              Grid.Column="2">

            <Grid.RowDefinitions>
                
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                
            </Grid.RowDefinitions>

            <!-- Right door selector. -->
            <views:DoorPanelSelectorView Grid.Row="0"
                                         DataContext="{Binding RightDoorPanel}"/>

            <!-- Right interactive door panel. -->
            <views:DoorPanelView Grid.Row="1"
                                 DataContext="{Binding RightDoorPanel.DoorState}"
                                 Margin="20"/>

        </Grid>


        <!--
            ##################### BOTTOM LEFT AREA #####################
            
                - Shared cardholder list.
                - Cardholders are shared across both door panels so the trainer can drag the same credential onto any of the four readers.
        -->
        <views:CardholdersView Grid.Row="1"
                               Grid.Column="0"
                               DataContext="{Binding Cardholders}"/>

        <!--
            ##################### BOTTOM RIGHT AREA #####################
            
                - Two Door-specific controls (Door interlocking controls area).
                - This view will contain:
                    - Door interlocking ON/OFF
                    - Override input selector
                    - Lockdown input selector
        -->
        <views:DoorInterlockingControlsView Grid.Row="1"
                                            Grid.Column="2"
                                            DataContext="{Binding Interlocking}"/>

    </Grid>
    
</UserControl>